<div class="container mx-auto px-4 py-6">
    <section class="bg-white/95 text-fm-primary rounded-lg p-6 mb-6 shadow-lg">
        <h2 class="font-display text-3xl md:text-4xl text-center my-6"><%= t('search.section.title') %></h2>
        <div class="grid md:grid-cols-2 gap-6">
            <div class="flex flex-col">
                <label for="cardname" class="mb-2 font-body"><%= t('search.input.label') %></label>
                <input
                    type="text"
                    id="cardname"
                    placeholder="<%= t('search.input.placeholder') %>"
                    class="w-full px-3 py-2 border border-fm-primary/30 rounded mb-4 font-body"
                />
                <div class="flex flex-wrap gap-2 mt-2" role="group">
                    <button type="button" id="search-name-btn" class="px-4 py-2 border border-emerald-600 text-emerald-700 rounded hover:bg-emerald-50 font-display text-sm">
                        <%= t('search.btn.by-name') %>
                    </button>
                    <button type="button" id="search-results-btn" class="px-4 py-2 border border-emerald-600 text-emerald-700 rounded hover:bg-emerald-50 font-display text-sm">
                        <%= t('search.btn.by-result') %>
                    </button>
                    <button type="button" id="reset-btn" class="px-4 py-2 bg-rose-600 text-white rounded hover:bg-rose-500 font-display text-sm w-44">
                        <%= t('search.btn.reset') %>
                    </button>
                </div>
            </div>
            <div class="flex justify-center">
                <div id="outputcard" class="w-full"></div>
            </div>
        </div>
    </section>

    <section class="bg-white/95 text-fm-primary rounded-lg p-6 shadow-lg">
        <h3 class="font-display text-2xl md:text-3xl text-center my-4"><%= t('search.results.title') %></h3>
        <span id="search-msg" class="block text-center"></span>
        <div class="grid md:grid-cols-2 gap-4 mt-4">
            <div id="output-area-left" class="flex flex-col items-center"></div>
            <div id="output-area-right" class="flex flex-col items-center"></div>
        </div>
    </section>
</div>
