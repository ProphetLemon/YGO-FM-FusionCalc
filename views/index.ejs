<section class="bg-vrains text-white">
    <div class="bg-black/40">
        <div class="container mx-auto px-4 py-12 md:py-20 grid md:grid-cols-2 gap-8 items-center">
            <div>
                <h1 class="text-3xl md:text-5xl font-display animate-hero-slide mb-2"><%= t('home.hero.title') %></h1>
                <h2 class="text-2xl md:text-3xl font-display animate-hero-slide mb-6"><%= t('home.hero.subtitle') %></h2>
                <p class="m-4 text-base md:text-lg font-body"><%= t('home.intro.p1') %></p>
                <p class="mx-4 mb-6 text-base md:text-lg font-body"><%= t('home.intro.p2') %></p>
                <div class="px-4 flex flex-wrap gap-3">
                    <a
                        href="/calculator"
                        class="inline-block px-6 py-3 bg-white text-black rounded font-display hover:bg-fm-search-bg transition-colors"
                    ><%= t('home.cta.calculator') %></a>
                    <a
                        href="/search"
                        class="inline-block px-6 py-3 bg-transparent border border-white text-white rounded font-display hover:bg-white/10 transition-colors"
                    ><%= t('home.cta.search') %></a>
                </div>
            </div>
            <div class="hidden sm:flex justify-center">
                <img
                    src="/public/images/cover_playstation.webp"
                    alt="<%= t('home.image.alt.cover') %>"
                    class="cover-glow max-w-full h-auto rounded shadow-lg"
                    loading="lazy"
                />
            </div>
        </div>
    </div>
</section>

<section class="bg-fm-search-bg text-fm-primary border-t-2 border-black">
    <div class="container mx-auto px-4 py-12 md:py-16 grid md:grid-cols-2 gap-8 items-center">
        <div>
            <h2 class="font-display text-3xl md:text-4xl mb-6">
                <span class="bg-fm-primary text-white px-3 py-1 inline-block hover:bg-blue-900 transition-colors"><%= t('home.section.search.title') %></span>
            </h2>
            <p class="text-lg md:text-xl font-body mb-6"><%= t('home.section.search.body') %></p>
            <a
                href="/search"
                class="inline-block px-6 py-3 bg-fm-primary text-white rounded font-display hover:bg-blue-900 transition-colors"
            ><%= t('home.section.search.cta') %></a>
        </div>
        <div class="flex justify-center pointer-events-none">
            <div class="md:hidden w-20 h-20 rounded-full bg-fm-primary flex items-center justify-center text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
            </div>
            <img src="/public/images/fusion.gif" alt="<%= t('home.image.alt.fusion') %>" class="hidden md:block max-w-full h-auto rounded" loading="lazy" />
        </div>
    </div>
</section>

<section class="bg-fm-calculator-bg text-fm-calculator-fg">
    <div class="container mx-auto px-4 py-12 md:py-16 grid md:grid-cols-2 gap-8 items-center">
        <div>
            <h2 class="font-display text-3xl md:text-4xl mb-6">
                <span class="bg-white px-3 py-1 inline-block hover:bg-orange-200 transition-colors"><%= t('home.section.calculator.title') %></span>
            </h2>
            <p class="text-lg md:text-xl font-body mb-2"><%= t('home.section.calculator.body') %></p>
            <p class="text-lg md:text-xl font-body mb-6"><%= t('home.section.calculator.body-2') %></p>
            <a
                href="/calculator"
                class="inline-block px-6 py-3 bg-white text-fm-calculator-fg rounded font-display hover:bg-orange-200 transition-colors"
            ><%= t('home.section.calculator.cta') %></a>
        </div>
        <div class="flex justify-center pointer-events-none">
            <div class="md:hidden w-20 h-20 rounded-full bg-white flex items-center justify-center text-fm-calculator-fg">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                </svg>
            </div>
            <img src="/public/images/atem.png" alt="<%= t('home.image.alt.atem') %>" class="hidden md:block max-w-full h-auto" loading="lazy" />
        </div>
    </div>
</section>
