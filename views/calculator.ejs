<div class="container mx-auto px-4 py-6">
    <section class="bg-white/95 text-fm-primary rounded-lg p-6 mb-6 shadow-lg">
        <h3 class="font-display text-2xl md:text-3xl my-4"><%= t('calculator.hand.title') %></h3>
        <div class="space-y-2">
            <% for (let i = 1; i <= 5; i++) { %>
                <div class="flex flex-wrap items-center gap-2">
                    <input
                        type="text"
                        id="hand<%= i %>"
                        class="flex-1 min-w-0 px-3 py-2 border border-fm-primary/30 rounded font-body"
                    />
                    <span id="hand<%= i %>-info" class="font-body"></span>
                </div>
            <% } %>
        </div>
        <button type="button" id="resetBtn" class="mt-6 px-4 py-2 bg-rose-600 text-white rounded hover:bg-rose-500 font-display text-sm w-44">
            <%= t('calculator.btn.reset') %>
        </button>
    </section>

    <section class="bg-white/95 text-fm-primary rounded-lg p-6 shadow-lg">
        <h4 class="font-display text-2xl md:text-3xl text-center my-4">
            <%= t('calculator.results.title') %>
            <span id="search-msg"></span>
        </h4>
        <div class="grid md:grid-cols-2 gap-4">
            <div id="outputarealeft"></div>
            <div id="outputarearight"></div>
        </div>
    </section>
</div>
