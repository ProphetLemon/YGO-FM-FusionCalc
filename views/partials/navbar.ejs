<header class="bg-white border-b border-black/10 font-body">
    <div class="container mx-auto px-4 py-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <a href="/" class="flex-shrink-0 ml-2 md:ml-4">
            <img src="/public/images/logo.png" alt="<%= t('nav.brand-alt') %>" class="h-8 md:h-10 w-auto" />
        </a>

        <button
            type="button"
            class="md:hidden self-end inline-flex flex-col items-center justify-center w-10 h-10 rounded border border-black/30 text-black"
            aria-label="<%= t('nav.toggle') %>"
            aria-expanded="false"
            aria-controls="primary-navigation"
            data-navbar-toggle
        >
            <span class="block w-5 h-0.5 bg-current"></span>
            <span class="block w-5 h-0.5 bg-current mt-1"></span>
            <span class="block w-5 h-0.5 bg-current mt-1"></span>
        </button>

        <nav
            id="primary-navigation"
            class="hidden md:flex flex-col md:flex-row md:items-center gap-2 md:gap-5 w-full md:w-auto md:ml-auto"
            data-navbar-collapse
        >
            <a
                href="/search"
                class="text-black hover:text-fm-primary <%= activeNav === 'search' ? 'font-semibold underline' : '' %>"
            ><%= t('nav.search') %></a>
            <a
                href="/calculator"
                class="text-black hover:text-fm-primary <%= activeNav === 'calculator' ? 'font-semibold underline' : '' %>"
            ><%= t('nav.calculator') %></a>
            <a
                href="/about"
                class="text-black hover:text-fm-primary <%= activeNav === 'about' ? 'font-semibold underline' : '' %>"
            ><%= t('nav.about') %></a>
            <a
                href="http://forums.somethingawful.com/showthread.php?threadid=3783156"
                rel="noopener noreferrer"
                target="_blank"
                class="inline-flex items-center px-3 py-1 rounded border border-black bg-white text-black hover:bg-black hover:text-white text-sm transition-colors"
            ><%= t('nav.thread') %></a>
            <%- include('language-switcher', { lang, t }) %>
        </nav>
    </div>
</header>
