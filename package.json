{
    "name": "ygo-fm-fusion-calc",
    "version": "0.9.0",
    "private": true,
    "type": "module",
    "description": "Yu-Gi-Oh! Forbidden Memories Fusion Calculator",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "nodemon",
        "build": "npm run typecheck && npm run build:client && npm run build:css && npm run build:server",
        "build:server": "tsc -p tsconfig.server.json",
        "build:client": "vite build",
        "build:css": "tailwindcss -i src/client/styles/tailwind.css -o public/dist/styles.css",
        "start": "node dist/server/index.js",
        "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "dotenv": "^16.4.5",
        "ejs": "^3.1.10",
        "express": "^5.0.1",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.50.0",
        "@tailwindcss/cli": "^4.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/node": "^24.0.0",
        "@types/supertest": "^6.0.3",
        "@vitest/coverage-v8": "^3.0.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.4.0",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vite": "^6.0.0",
        "vitest": "^3.0.0"
    }
}
